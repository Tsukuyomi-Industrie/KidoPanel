NODE_ENV=development

# Passerelle : secret JWT obligatoire ; URL du moteur de conteneurs (optionnel).
GATEWAY_JWT_SECRET=remplacer-par-une-chaine-longue-et-aleatoire
CONTAINER_ENGINE_BASE_URL=http://127.0.0.1:8787

# Service instances jeu : par défaut la passerelle relaie vers http://127.0.0.1:8790 (même hôte que le panel).
# Le processus « server-service » doit être démarré : à la racine « pnpm dev » (turbo lance tous les paquets ayant un script dev) OU terminal dédié « pnpm dev:server-service ».
# Sans processus sur 8790, la création Minecraft / autres jeux renvoie une erreur « impossible de joindre le service instances jeu ».
# Contrôle rapide : curl -sSf http://127.0.0.1:8790/health (réponse JSON status ok si le service écoute).
#
# Si la passerelle tourne dans Docker et server-service sur l’hôte Linux : SERVER_SERVICE_BASE_URL=http://172.17.0.1:8790 ou l’IP réelle de l’hôte vue depuis le conteneur ; sous Docker Desktop : souvent http://host.docker.internal:8790
# Et faire écouter server-service sur toutes les interfaces : SERVER_SERVICE_LISTEN_HOST=0.0.0.0 (sinon seul 127.0.0.1 accepte les connexions locales à la machine).
# Pour une autre URL ou un autre hôte :
# SERVER_SERVICE_BASE_URL=http://127.0.0.1:8790
# Pour désactiver les routes « Serveurs de jeu » (pas de relais /serveurs-jeux) :
# SERVER_SERVICE_DISABLED=1

# Passerelle : écoute sur toutes les interfaces réseau (requis pour joindre le port 3000 via l’IP publique du VPS).
GATEWAY_LISTEN_HOST=0.0.0.0

# Moteur Docker : par défaut seulement loopback (la passerelle appelle 127.0.0.1:8787 sur la même machine).
# CONTAINER_ENGINE_LISTEN_HOST=127.0.0.1

# Moteur : répertoire des fichiers `<id_docker_complet>.log` (événements + sortie stdout/stderr capturée après chaque démarrage). Par défaut : ./donnees/journaux-conteneurs-moteur/ depuis le cwd du processus.
# CONTAINER_ENGINE_JOURNAUX_CONTENEURS_DIR=/var/log/kidopanel/conteneurs

# Limite de requêtes passerelle (fenêtre glissante). Augmenter si le panel de test déclenche trop de 429.
# GATEWAY_RATE_LIMIT_MAX=120
# GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# PostgreSQL (docker-compose : utilisateur / mot de passe / base « kydopanel » sur le port 5432).
DATABASE_URL=postgresql://kydopanel:kydopanel@127.0.0.1:5432/kydopanel
