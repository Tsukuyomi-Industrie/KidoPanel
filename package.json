{
  "name": "kidopanel",
  "version": "1.0.0",
  "description": "Plateforme PaaS pour serveurs de jeux et hébergement web (KidoPanel)",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:server-service": "pnpm --filter server-service dev",
    "dev:web-service": "pnpm --filter web-service dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "rm -rf node_modules **/node_modules **/dist"
  },
  "keywords": [
    "paas",
    "docker",
    "serveurs-de-jeux",
    "hebergement-web",
    "panel",
    "kidopanel"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  }
}
