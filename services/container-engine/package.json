{
  "name": "container-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API de cycle de vie des conteneurs Docker pour KydoPanel",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
