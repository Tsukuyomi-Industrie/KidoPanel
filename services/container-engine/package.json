{
  "name": "container-engine",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.12"
  },
  "type": "module",
  "description": "API de cycle de vie des conteneurs Docker pour KidoPanel",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc && (tsc --watch --preserveWatchOutput & node --watch dist/main.js)",
    "lint": "node -e \"\"",
    "start": "node dist/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@kidopanel/database": "workspace:*",
    "@kidopanel/container-catalog": "workspace:*",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "dockerode": "^4.0.9",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^24.12.2",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
