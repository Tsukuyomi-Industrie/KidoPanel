{
  "name": "@kidopanel/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Client Prisma partagé et schéma PostgreSQL pour KidoPanel",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./charger-env-racine-monorepo": {
      "types": "./dist/charger-env-racine-monorepo.d.ts",
      "import": "./dist/charger-env-racine-monorepo.js"
    },
    "./journal-json-service-stdout": {
      "types": "./dist/journal-json-service-stdout.d.ts",
      "import": "./dist/journal-json-service-stdout.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "node -e \"\"",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^16.6.1",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "prisma": "^6.19.0",
    "typescript": "^6.0.2"
  }
}
